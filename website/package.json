    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/language-plugin-pug": "^3.2.5",
    "@vue/tsconfig": "^0.8.1",
    "pug": "^3.0.3",
    "sass": "^1.97.3",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  }
