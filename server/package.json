{
  "name": "little-bible-stories-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e .env.local -- tsx watch src/index.ts",
    "build": "dotenv -e .env --  tsc -p tsconfig.build.json",
    "start": "dotenv -e .env -- node dist/index.js",
    "build:prod": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/index.js",
    "type-check": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:test-to-main": "dotenv -e .env.local -- tsx scripts/migrate-test-to-main.ts",
    "migrate:content-cover-image": "dotenv -e .env.local -- tsx scripts/migrate-content-cover-image.ts",
    "translate:books": "dotenv -e .env.local -- tsx scripts/translate-books.ts",
    "migrate:rewrite-upload-urls": "dotenv -e .env.local -- tsx scripts/migrate-rewrite-upload-urls.ts"
  },
  "dependencies": {
    "@sentry/node": "^8.45.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "mime-types": "^2.1.35",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.11.0",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "ioredis-mock": "^8.9.0",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
