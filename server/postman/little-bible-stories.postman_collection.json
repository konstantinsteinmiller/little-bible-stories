{
  "info": {
    "name": "Little Bible Stories API",
    "_postman_id": "c7f2f3a1-4c2d-4a9b-9f2b-9f2b9f2b9f2b",
    "description": "Full API surface for the Little Bible Stories backend. Uses the environment file for {{baseUrl}}, {{adminUser}}, {{adminPassword}}. The collection-level pre-request script applies HTTP Basic Auth to every secured call.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{adminUser}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{adminPassword}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Apply Basic Auth only to requests that are marked as secured.",
          "// Read endpoints can override auth: 'noauth' in their request config.",
          "const user = pm.environment.get('adminUser') || 'admin';",
          "const pass = pm.environment.get('adminPassword') || 'little-bible-stories-2026!';",
          "pm.variables.set('adminUser', user);",
          "pm.variables.set('adminPassword', pass);"
        ]
      }
    }
  ],
