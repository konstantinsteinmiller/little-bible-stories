# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# MongoDB Atlas — replace <user>, <password>, <cluster>, <database>
MONGO_URI=mongodb+srv://user:<pass>@cluster0.lhlvowv.mongodb.net/?appName=Cluster0&retryWrites=true&w=majority
MONGO_DB_NAME=main_db

# Redis — Upstash / Render Redis / local
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
CACHE_TTL_SECONDS=600

# Admin UI basic-auth
ADMIN_USER=
ADMIN_PASSWORD=

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Paths (absolute or relative to server/)
AUDIOBOOKS_DIR=./audiobooks
UPLOADS_DIR=./uploads

# Translation model cache (optional)
HF_HOME=./.cache/huggingface
TRANSLATION_ENABLED=true
# ONNX weight precision: fp32 | fp16 | q8 | q4 (q8 is default, ~80 MB per pair)
TRANSLATION_DTYPE=q8

# Public base URL used to construct asset URLs returned by upload endpoints
PUBLIC_BASE_URL=http://localhost:4000

# Sentry crash reporting — leave blank to disable.
# Create two projects on sentry.io: "kanaan-stories-server" (Node/Express) and "kanaan-stories-adminui" (Vue).
# Get each DSN from Settings → Projects → <project> → Client Keys.
SENTRY_DSN=
# VITE_ prefix is required so Vite inlines it into the admin UI build.
VITE_SENTRY_DSN=
# Optional: set to the current git SHA in CI to tag events with a release.
SENTRY_RELEASE=
VITE_SENTRY_RELEASE=
