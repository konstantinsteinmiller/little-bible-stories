{
  "name": "little-bible-stories",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./electron/out/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "build-github-main": "vite build --base=/little-bible-stories/ --outDir=dist",
    "build-github-develop": "vite build --base=/little-bible-stories/develop/ --outDir=dist/develop",
    "build-github-demo": "vite build --mode demo --base=/little-bible-stories/demo/ --outDir=dist/demo",
    "validated-build": "vue-tsc -b && vite build",
    "deploy": "vite build && surge dist/ --domain little-bible-stories.surge.sh",
    "deploy-demo": "vite build --mode demo && surge dist/ --domain little-bible-stories-demo.surge.sh",
    "type-check": "vue-tsc --build",
    "format": "prettier --write --experimental-cli src",
    "test": "vitest",
    "visualize-bundle": "npx vite-bundle-visualizer",
    "native-dev": "dotenv -e .env.native -- electron-vite dev",
    "native-dev:demo": "dotenv -e .env.nativedemo -- electron-vite dev",
    "native-build": "electron-vite build",
    "native-preview": "electron-vite preview",
    "native-package:demo": "dotenv -e .env.nativedemo -- pnpm run native-build && electron-builder --config.productName=\"Seedolino Demo\" --config.nsis.shortcutName=\"Seedolino Demo\" --config.directories.output=\"electron/dist-demo\" --config.win.artifactName=\"${productName}-Setup-${version}.${ext}\"",
    "native-package": "dotenv -e .env.native -- pnpm run native-build && electron-builder",
    "align:extract": "node scripts/extract-page-text.mjs --key fa-1 --lang de --page 1 --out scripts/align-input/fa-1-de-page-1.txt",
    "align:audio": "node scripts/align-audio.mjs --audio public/audiobooks/fruit-agents/volume-1/de-fruit-agents-volume-1-page-1.ogg --text scripts/align-input/fa-1-de-page-1.txt --lang de --out public/audiobooks/fruit-agents/volume-1/de-fruit-agents-volume-1-page-1.align.json",
    "align:extract-book": "node scripts/extract-page-text.mjs --key fa-1 --lang de --pages all --out scripts/align-input/fa-1-de.txt",
    "align:audio-book": "node scripts/align-audio.mjs --audio public/audiobooks/fruit-agents/volume-1/de-fruit-agents-volume-1.ogg --text scripts/align-input/fa-1-de.txt --lang de --out public/audiobooks/fruit-agents/volume-1/de-fruit-agents-volume-1.align.json"
  },
  "build": {
    "appId": "com.game.kanaanstories",
    "productName": "Seedolino",
    "directories": {
      "output": "electron/dist",
      "buildResources": "electron/resources"
    },
    "win": {
      "icon": "electron/resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Seedolino"
    },
    "files": [
      "electron/out/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "canvas-confetti": "^1.9.4",
    "lodash.clonedeep": "^4.5.0",
    "pdfjs-dist": "4.10.38",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@huggingface/transformers": "^3.0.0",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/lodash.clonedeep": "^4.5.9",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/language-plugin-pug": "^3.2.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.27",
    "biome-tailwind-sorter": "^0.2.8",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "ffmpeg-static": "^5.3.0",
    "fibers": "^5.0.3",
    "jsdom": "^27.4.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "pug": "^3.0.3",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^25.5.0 || >=22.12.0"
  },
  "pnpm": {
    "overrides": {
      "jsdom": "^27.4.0"
    }
  }
}
